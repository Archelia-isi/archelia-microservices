// === ZUCCHETTI SKU SEQUENCE MAP ===

/// Mappa che mantiene in memoria l'high-water mark (ultimo numero usato) per ogni prefisso SKU
model SkuSequenceMap {
  prefix      String   @id // Es: "ILPALA", "E14", "CA"
  lastNumber  Int      @default(0) // L'ultimo numero usato (es. 104 per ILPALA00104)
  updatedAt   DateTime @updatedAt

  @@map("sku_sequence_map")
}

// === EQUALIZZATORE: STAGING E REVISIONE UMANA ===

/// Modello di appoggio temporaneo dove l'IA salva i suoi risultati a 3 Fasi.
/// Nessun dato viene sovrascritto sul database web/Zucchetti finché non viene approvato qui.
model EqualizzatoreStaging {
  id             String   @id @default(cuid())
  
  /// Riferimento al prodotto originale (potrebbe essere un ID di elmark_raw_product o elmark_processed_product)
  sourceId       String   @unique
  sku            String?  @unique

  /// Fase 1: Output Tecnico Tassonomico (JSON da Gemini)
  phase1Payload  Json?
  
  /// Fase 2: Output Visivo (JSON da Gemini Vision)
  phase2Payload  Json?
  
  /// Fase 3: Output Copywriting (JSON da Claude 3.5 Sonnet)
  phase3Payload  Json?

  /// Gestione concorrenza
  lockedBy       String?
  lockedAt       DateTime?

  /// Stato di avanzamento
  status         String   @default("PENDING_PHASE1") // PENDING_PHASE1, PENDING_PHASE2, PENDING_PHASE3, PENDING_NOMENCLATURE, PENDING_DUPLICATE_CHECK, READY_FOR_SYNC, SYNCED, DISCARDED

  /// Payload approvato dall'utente nella Review Station
  approvedPayload Json?

  /// Stato di avanzamento della pipeline IA: "PENDING", "PHASE_1_DONE", "PHASE_2_DONE", "PHASE_3_DONE", "ERROR"
  pipelineStatus String   @default("PENDING")

  /// Stato della review umana: "PENDING", "APPROVED", "REJECTED"
  reviewStatus   String   @default("PENDING")

  /// Log di eventuali errori dell'IA
  errorMessage   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([pipelineStatus])
  @@index([reviewStatus])
  @@map("equalizzatore_staging")
}

/// Tabella temporanea per lo staging della nomenclatura prima dell'allineamento semantico.
model TaxonomyStaging {
  id             String   @id @default(cuid())
  
  /// Riferimento al prodotto in EqualizzatoreStaging (es. EC660163M)
  sourceId       String   @unique
  
  /// Nomenclatura testuale proposta dall'IA in Fase 1
  proposedGroup      String?
  proposedFamily     String?
  proposedCategory   String?

  /// Nomenclatura normalizzata e codici a 3 lettere dopo Fase 2 e 3
  finalGroupCode     String?
  finalFamilyCode    String?
  finalCategoryCode  String?

  /// Stato della nomenclatura: "PENDING", "CLUSTERED", "MATCHED", "ERROR"
  status         String   @default("PENDING")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@map("taxonomy_staging")
}

model EqualizzatoreUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  rawPassword  String?
  role         String    @default("OPERATOR") // ADMIN, OPERATOR
  displayName  String?
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
